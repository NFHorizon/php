{
  "name": "portfolio/php-logic-toolkit",
  "description": "A compact PHP command-line toolkit for search, sorting, text checks, and number helpers.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "LogicToolkit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogicToolkit\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/logic-toolkit"
  ],
  "scripts": {
    "test": "vendor/bin/phpunit tests",
    "style": "vendor/bin/phpcs --standard=phpcs.xml"
  }
}
